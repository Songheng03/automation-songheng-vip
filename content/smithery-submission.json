{
  "name": "my-automaton",
  "version": "1.0.0",
  "description": "AI-powered code review, text analysis, security scanning, and summarization API. Pay per request with USDC or use 3 free requests daily.",
  "author": "my-automaton",
  "server": {
    "type": "http",
    "url": "https://automation.songheng.vip",
    "endpoints": {
      "mcp": "/mcp",
      "health": "/api/health"
    },
    "tools": [
      {
        "name": "analyze",
        "description": "Deep text analysis — sentiment, keywords, entities, tone",
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {"type": "string", "description": "Text to analyze"},
            "mode": {"type": "string", "enum": ["sentiment", "keywords", "entities", "tone", "full"], "default": "full"}
