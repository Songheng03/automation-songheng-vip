    "endpoint": "/mcp",
    "method": "POST",
    "description": "MCP JSON-RPC endpoint. Main API gateway for invoking tools and listing available capabilities. Supports methods: tools/list, tools/call.",
    "request_format": {
      "jsonrpc": "2.0",
      "id": "number",
      "method": "string (either 'tools/list' or 'tools/call')",
      "params": {
        "name": "string (for tools/call)",
        "arguments": "object (for tools/call)"
      }
    },
    "response_format": {
      "jsonrpc": "2.0",
      "id": "number",
      "result": "object - either has 'tools' array (from tools/list) or 'content' array (from tools/call)"
    },
    "pricing": "Varies per tool (see individual tool endpoints)"
  },
