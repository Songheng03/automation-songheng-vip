async function freeHandler(req,res,mode){
  const ip=req.headers['x-forwarded-for']||req.connection.remoteAddress||'u';
  const c=fc(ip);uf(ip);
  if(c>=3)return res.status(429).json({error:'Free limit reached (3/day). Upgrade at /upgrade',upgrade:B+'/upgrade',wallet:W});
  const {text,code,content}=req.body||{};const input=text||code||content||'';
  if(!input)return res.status(400).json({error:'No input provided'});
  tr('/free/'+mode,'f',ip);
  try{
    const prompt={security:'Security scan. Return JSON {issues:[{severity,line,description,fix}],score:0-100}. Code:\n'+input,review:'Code review. Return JSON {issues:[{severity,line,description,suggestion}],score:0-100,summary}. Code:\n'+input,summarize:'Summarize. Return JSON {summary,keyPoints:[],wordCount}. Text:\n'+input,explain:'Explain code. Return JSON {overview,lineByLine:[],complexity}. Code:\n'+input,analyze:'Deep analysis. Return JSON {sentiment,tone,keyThemes:[],readabilityScore,summary,entities:[]}. Text:\n'+input}[mode]||('Analyze. Return JSON. Input:\n'+input);
    const r=await ai([{role:'user',content:prompt}]);
    const j=JSON.parse(r.replace(/^```json?\s*/,'').replace(/\s*```$/,''));
    res.json({...j,mode,wallet:W,upgrade:B+'/upgrade',free_remaining:2-c});
  }catch(e){res.status(500).json({error:e.message,mode,wallet:W});}
}
['analyze','summarize','review','security','explain'].forEach(m=>{a.post('/free/'+m,(r,s)=>freeHandler(r,s,m));});

