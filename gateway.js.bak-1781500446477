  tr('/v1/'+mode,'p','api');
  try{
    const prompts={security:'Security scan. Return JSON {issues:[{severity,line,description,fix}],score:0-100}. Code:\n'+input,review:'Senior code review. Return JSON {issues:[{severity,line,description,suggestion}],score:0-100,summary}. Code:\n'+input,summarize:'Summarize. Return JSON {summary,keyPoints:[],wordCount}. Text:\n'+input,explain:'Explain code. Return JSON {overview,lineByLine:[],complexity}. Code:\n'+input,analyze:'Deep analysis. Return JSON {sentiment,tone,keyThemes:[],readabilityScore,summary,entities:[]}. Text:\n'+input,refactor:'Refactoring. Return JSON {suggestions:[{issue,refactoredCode,explanation}],score,summary}. Code:\n'+input,complexity:'Complexity analysis. Return JSON {cyclomaticScore,lines,functions:[{name,params,complexity}],suggestions:[],overall}. Code:\n'+input,batch:'Batch process. Return JSON {results:[{index,summary,sentiment,keyPoints}]}. Texts:\n'+input,render:'Render markdown to HTML:\n'+input};
