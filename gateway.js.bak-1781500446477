      case'ping':return s.json({jsonrpc:'2.0',id,result:{}});
      default:return s.json({jsonrpc:'2.0',id,error:{code:-32601,message:'Not found: '+method}});
    }
  }catch(e){s.json({jsonrpc:'2.0',id:null,error:{code:-32700,message:'Parse error'}});}
});

