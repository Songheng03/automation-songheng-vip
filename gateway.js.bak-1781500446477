a.post('/mcp/jsonrpc',(r,s)=>{
  try{const {id,method,params}=r.body;
    switch(method){
      case'initialize':return s.json({jsonrpc:'2.0',id,result:{protocolVersion:'2024-11-05',capabilities:{tools:{},resources:{}},serverInfo:{name:'my-automaton',version:'1.0.0'}}});
      case'tools/list':return s.json({jsonrpc:'2.0',id,result:{tools:MCP_TOOLS}});
      case'tools/call':{const text=params?.arguments?.code||params?.arguments?.text||'';return s.json({jsonrpc:'2.0',id,result:{content:[{type:'text',text:`Use POST ${B}/v1/${params?.name?.replace('_','')} with X-API-Key header. Free: POST ${B}/free/analyze`}],isError:false}});}
