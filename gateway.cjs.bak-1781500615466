function loadApiKeys() {
  try { return JSON.parse(fs.readFileSync(API_KEYS_FILE, 'utf8')); } catch(e) { return {}; }
}
function saveApiKeys(keys) { fs.writeFileSync(API_KEYS_FILE, JSON.stringify(keys, null, 2)); }
function generateApiKey() { return 'am_' + crypto.randomBytes(24).toString('hex'); }
function getCredits(key) { const keys = loadApiKeys(); return keys[key]?.credits || 0; }
function deductCredits(key, amount) {
  const keys = loadApiKeys(); const e = keys[key];
  if (!e || (e.credits||0) < amount) return false;
  e.credits -= amount; e.used = (e.used||0) + 1; e.last_used = new Date().toISOString();
  saveApiKeys(keys); return true;
}

const PRICE_CREDITS = {
  'price_1TiOLADly2uoyjDjIR8RVnTl': 500,
  'price_1TiOLXDly2uoyjDj0UEar0Un': 1100,
