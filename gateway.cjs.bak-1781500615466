// Free tier
const freeUsage = {};
function checkFree(ip) {
  const t = new Date().toISOString().slice(0,10);
  if (!freeUsage[ip]) freeUsage[ip]={date:t,count:0};
  if (freeUsage[ip].date!==t) freeUsage[ip]={date:t,count:0};
  return freeUsage[ip].count<3;
}
function incFree(ip) {
  const t = new Date().toISOString().slice(0,10);
  if (!freeUsage[ip]) freeUsage[ip]={date:t,count:0};
  if (freeUsage[ip].date!==t) freeUsage[ip]={date:t,count:0};
  freeUsage[ip].count++;
}
for (const name of ['analyze','summarize','review','security','explain']) {
  app.post('/free/' + name, async (req, res) => {
    const ip = req.ip || req.connection?.remoteAddress || 'unknown';
    if (!checkFree(ip)) return res.status(429).json({error:'Free limit reached (3/day)'});
    const text = req.body?.text || '';
    if (!text) return res.status(400).json({error:'text required'});
    try { incFree(ip); const r = await callAI([{role:'system',content:name},{role:'user',content:text}]); res.json({result:r, free_remaining:3-freeUsage[ip].count}); }
    catch(e) { res.status(500).json({error:e.message}); }
  });
}

