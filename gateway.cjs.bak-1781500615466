};

function addCredits(email, priceId) {
  const credits = PRICE_CREDITS[priceId]; if (!credits) return null;
  const e = (email || '').toLowerCase().trim();
  const keys = loadApiKeys();
  if (e && emailToKey[e] && keys[emailToKey[e]]) {
    const k = emailToKey[e]; keys[k].credits += credits;
    keys[k].topups = (keys[k].topups || 0) + 1; keys[k].last_topup = new Date().toISOString();
    saveApiKeys(keys); return { key: k, credits: keys[k].credits, topup: true };
  }
  const key = generateApiKey();
  keys[key] = { credits, created: new Date().toISOString(), used: 0, price_id: priceId, topups: 0 };
  if (e) emailToKey[e] = key; saveApiKeys(keys); saveEmailKeys();
  return { key, credits, topup: false };
}

function requireAuth(req, res, next) {
  const k = req.headers['x-api-key'] || req.headers['authorization']?.replace('Bearer ', '');
  if (!k) return res.status(401).json({ error: 'Missing API key. Get one at /upgrade' });
  const c = getCredits(k); if (c <= 0) return res.status(402).json({ error: 'Insufficient credits. Top up at /upgrade', credits: 0 });
  req.apiKey = k; req.credits = c; next();
}

async function callAI(messages, opts) {
  if (!DEEPSEEK_API_KEY) return 'AI service not configured.';
  const r = await fetch(DEEPSEEK_BASE + '/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + DEEPSEEK_API_KEY },
    body: JSON.stringify({ model: opts?.model || 'deepseek-chat', messages, max_tokens: opts?.max_tokens || 2048, temperature: opts?.temperature || 0.3 })
  });
  if (!r.ok) throw new Error('DeepSeek API ' + r.status);
  const d = await r.json(); return d.choices[0].message.content;
}


