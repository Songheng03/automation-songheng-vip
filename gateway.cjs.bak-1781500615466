app.post('/api/stripe/checkout', async (req, res) => {
  const { price_id, email } = req.body || {};
  if (!price_id || !PRICE_CREDITS[price_id]) return res.status(400).json({ error: 'Invalid price ID' });
  if (!STRIPE_SK) return res.status(503).json({ error: 'Stripe not configured' });
  try {
    const stripe = require('stripe')(STRIPE_SK);
    const session = await stripe.checkout.sessions.create({
      mode:'payment', line_items:[{price:price_id,quantity:1}],
      customer_email:email||undefined,
      success_url:BASE_URL+'/thank-you?session_id={CHECKOUT_SESSION_ID}',
      cancel_url:BASE_URL+'/upgrade',
      metadata:{email:email||'',price_id}
    });
    res.json({url:session.url});
  } catch(e) { res.status(500).json({error:e.message}); }
});

// Stripe webhook
app.post('/api/stripe-webhook', async (req, res) => {
  if (!STRIPE_SK) return res.status(503).json({ error: 'Stripe not configured' });
  try {
    const stripe = require('stripe')(STRIPE_SK);
    const sig = req.headers['stripe-signature'];
    const event = stripe.webhooks.constructEvent(JSON.stringify(req.body), sig, process.env.STRIPE_WHSEC || '');
    if (event.type === 'checkout.session.completed') {
      const s = event.data.object;
      const email = s.metadata?.email || s.customer_details?.email || '';
      const priceId = s.metadata?.price_id || '';
      const result = addCredits(email, priceId);
      if (result) console.log('[STRIPE] Payment:', email||'?', result.credits, 'credits', result.topup?'topup':'new');
    }
    res.json({received:true});
  } catch(e) { console.error('[STRIPE] Webhook error:', e.message); res.status(400).json({error:e.message}); }
});

// Checkout result
app.get('/api/checkout-result', async (req, res) => {
  const sessionId = req.query.session_id; if (!sessionId) return res.status(400).json({error:'session_id required'});
  if (!STRIPE_SK) return res.status(503).json({error:'Stripe not configured'});
  try {
    const stripe = require('stripe')(STRIPE_SK);
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    const email = session.metadata?.email || session.customer_details?.email || '';
    if (!email) return res.json({status:'pending',email:null});
    const k = emailToKey[email]; const keys = loadApiKeys();
    if (k && keys[k]) return res.json({status:'ready',email,key_masked:k.slice(0,6)+'...'+k.slice(-4),key_full:k,credits:keys[k].credits,topup:(keys[k].topups||0)>0});
    const result = addCredits(email, session.metadata?.price_id||'');
    if (result) return res.json({status:'ready',email,key_masked:result.key.slice(0,6)+'...'+result.key.slice(-4),key_full:result.key,credits:result.credits,topup:result.topup});
    res.json({status:'pending'});
  } catch(e) { res.status(500).json({error:e.message}); }
});

